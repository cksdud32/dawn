generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(cuid())
  sessionKey String    @unique
  anonName   String
  createdAt  DateTime  @default(now())
  posts      Post[]
  comments   Comment[]
}

model Post {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  content     String
  mood        String?
  musicTitle  String?
  musicArtist String?
  dawnDate    String
  createdAt   DateTime  @default(now())
  comments    Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
}
